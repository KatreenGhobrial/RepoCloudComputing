        "def ensure_game_data_shape(data):\n",
        "    \"\"\"Keep Firebase game data compatible when old records are missing new fields.\"\"\"\n",
        "    defaults = default_game_data()\n",
        "\n",
        "    if not isinstance(data, dict):\n",
